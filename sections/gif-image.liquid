                      image: block.settings.image.src,
                      columns_desktop: 2,
                      columns_tablet: 2,
                      columns_mobile: 1.0,
                      section_width: section.settings.width
                    %}
                  {%- endcapture -%}

                  {% render 'image-parallax', img_object: block.settings.image.src, frame_height_class: section.settings.height, srcset: srcset, sizes: video_block_sizes, preload: preload, loading: loading, fetchpriority: fetchpriority %}
                {% endif %}
