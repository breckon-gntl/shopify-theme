          src="{{ image | image_url }}"
          class="gif-frame"
          style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; display: {% if forloop.first %}block{% else %}none{% endif %};"
          loading="lazy"
        />
      {% endfor %}
    </div>
  </div>
</div>

