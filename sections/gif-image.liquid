{% schema %}
{
  "name": "Pair GIF with text",
  "settings": [],
  "blocks": [
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker",
          "default": "Image with text"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>"
        }
      ]
    },
    {
      "type": "gif_images",
      "name": "GIF Images",
      "settings": [
        {
          "type": "range",
          "id": "frame_delay",
          "min": 500,
          "max": 5000,
          "step": 100,
          "unit": "ms",
          "label": "Frame delay",
          "default": 1000
        },
        {
          "type": "image_picker",
          "id": "frame_0",
          "label": "Frame 1"
        },
        {
          "type": "image_picker",
          "id": "frame_1",
          "label": "Frame 2"
        },
        {
          "type": "image_picker",
          "id": "frame_2",
          "label": "Frame 3"
        },
        {
          "type": "image_picker",
          "id": "frame_3",
          "label": "Frame 4"
        },
        {
          "type": "image_picker",
          "id": "frame_4",
          "label": "Frame 5"
        },
        {
          "type": "image_picker",
          "id": "frame_5",
          "label": "Frame 6"
        },
        {
          "type": "image_picker",
          "id": "frame_6",
          "label": "Frame 7"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pair GIF with text",
      "blocks": [
        {
          "type": "text"
        },
        {
          "type": "gif_images"
        }
      ]
    }
  ]
}
{% endschema %}