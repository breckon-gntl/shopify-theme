<!-- /snippets/product-price.liquid -->
{%- liquid
  assign current_variant = product.selected_or_first_available_variant

  if block.settings.price_size
    assign price_size_class = block.settings.price_size | prepend: 'accent-size-'
    assign price_small_class = block.settings.price_size | minus: 1 | prepend: 'accent-size-'
  endif
-%}

<div class="product__block__price" style="--PB: {{ block.settings.padding_bottom }}px;" {{ block.shopify_attributes }}>
  <div class="product__price__wrap">
    <div class="product__price__main" data-price-wrapper>
      <span class="product__price {{ price_size_class }}">
        <span data-product-price {% if current_variant.compare_at_price > current_variant.price %} class="product__price--sale"{% endif %}>
          {%- if settings.currency_code_enable -%}
            {{ current_variant.price | money_with_currency }}
          {%- else -%}
            {{ current_variant.price | money }}
          {%- endif -%}
        </span>
      </span>

      <span data-price-off class="product__price--off hide">
        <span data-price-off-type>{{ 'products.product.sale' | t }}</span>
        <em>•</em>
        {{ 'products.product.save' | t }}
        <span data-price-off-amount></span>
      </span>

      {% liquid
        assign units = product.variants | map: 'unit_price' | compact
        if units[0]
          assign has_units = true
        else
          assign has_units = false
        endif
      %}
      {% if has_units %}
        {% capture show_units %}
          {%- unless current_variant.unit_price -%}style="display: none;"{%- endunless -%}
        {% endcapture %}
        {% capture unit_price_separator %}
          <span aria-hidden="true">/</span><span class="visually-hidden">{{ 'general.accessibility.unit_price_separator' | t }}&nbsp;</span>
        {% endcapture %}
        {% capture unit_price_base_unit %}
          <span>
            {% if current_variant.unit_price_measurement %}
              {% if current_variant.unit_price_measurement.reference_value != 1 %}
                {{ current_variant.unit_price_measurement.reference_value }}
              {%- endif -%}
              {{ current_variant.unit_price_measurement.reference_unit }}
            {% endif %}
          </span>
        {% endcapture %}
        <div class="product__price--unit {{ price_small_class }}">
          <span data-product-unit {{ show_units }}>
            <span class="visually-hidden visually-hidden--inline">{{ 'products.product.unit_price_label' | t }}</span>
            <span data-product-unit-price id="unit-price-{{ block.id }}">
              {%- if settings.currency_code_enable -%}
                {{ current_variant.unit_price | money_with_currency }}
              {%- else -%}
                {{ current_variant.unit_price | money }}
              {%- endif -%}
            </span>
            {{ unit_price_separator }}
            <span data-product-base id="unit-price-base-{{ block.id }}">{{ unit_price_base_unit }}</span>
          </span>
          <span data-price-each class="hide">
            {{ 'products.product.each' | t }}
            <span data-price-each-amount></span>
          </span>
        </div>
      {% endif %}
    </div>
</div>
  {%- assign fs_limit = settings.free_shipping_limit | plus: 0 -%}
  {%- if fs_limit > 0 -%}
    {%- assign fs_limit_cents = fs_limit | times: 100 -%}
    {%- assign remaining_cents = fs_limit_cents | minus: cart.total_price -%}
    {%- if remaining_cents < 0 -%}{%- assign remaining_cents = 0 -%}{%- endif -%}
    {%- assign additional_units = 0 -%}
    {%- if remaining_cents > 0 and current_variant.price > 0 -%}
      {%- assign additional_units = remaining_cents | plus: current_variant.price | minus: 1 | divided_by: current_variant.price -%}
    {%- endif -%}
    <p
      class="product__shipping-note body-size-3"
      style="margin-top:8px;opacity:0.7;"
      data-pdp-shipping-note
      data-free-shipping-limit="{{ fs_limit_cents }}"
      data-cart-total="{{ cart.total_price }}"
      data-variant-price="{{ current_variant.price }}">
      <span data-pdp-shipping-default{% if remaining_cents <= 0 %} class="hide"{% endif %}>
        Spend <span data-pdp-shipping-amount>{{ remaining_cents | money_without_trailing_zeros }}</span> more for free shipping
        <span data-pdp-shipping-qty-wrap{% if additional_units <= 0 %} class="hide"{% endif %}>&thinsp;&middot;&thinsp;add <span data-pdp-shipping-qty>{{ additional_units }}</span> or more to unlock.</span>
      </span>
      <span data-pdp-shipping-success{% if remaining_cents > 0 %} class="hide"{% endif %}>You've unlocked free shipping.</span>
    </p>
    <script>
      (function () {
        function formatPdpMoney(cents) {
          var amount = Math.max(0, Number(cents) || 0) / 100;
          var currency = (window.theme && window.theme.currencyCode) || '{{ cart.currency.iso_code }}';
          var locale = document.documentElement.lang || undefined;
          var hasWholeAmount = Math.round(amount * 100) % 100 === 0;

          try {
            return new Intl.NumberFormat(locale, {
              style: 'currency',
              currency: currency,
              minimumFractionDigits: hasWholeAmount ? 0 : 2,
              maximumFractionDigits: 2
            }).format(amount);
          } catch (error) {
            return '$' + (hasWholeAmount ? amount.toFixed(0) : amount.toFixed(2));
          }
        }

        function initShippingNote(note) {
          if (!note || note.dataset.shippingReady === 'true') return;
          note.dataset.shippingReady = 'true';

          var section = note.closest('.shopify-section') || document;
          var limitCents = parseInt(note.getAttribute('data-free-shipping-limit'), 10) || 0;
          var cartTotalCents = parseInt(note.getAttribute('data-cart-total'), 10) || 0;
          var variantPriceCents = parseInt(note.getAttribute('data-variant-price'), 10) || 0;

          var defaultEl = note.querySelector('[data-pdp-shipping-default]');
          var successEl = note.querySelector('[data-pdp-shipping-success]');
          var amountEl = note.querySelector('[data-pdp-shipping-amount]');
          var qtyWrapEl = note.querySelector('[data-pdp-shipping-qty-wrap]');
          var qtyEl = note.querySelector('[data-pdp-shipping-qty]');

          function render() {
            var remainingCents = Math.max(limitCents - cartTotalCents, 0);
            var additionalUnits = remainingCents > 0 && variantPriceCents > 0
              ? Math.ceil(remainingCents / variantPriceCents)
              : 0;

            if (amountEl) amountEl.textContent = formatPdpMoney(remainingCents);
            if (qtyEl) qtyEl.textContent = additionalUnits;
            if (qtyWrapEl) qtyWrapEl.classList.toggle('hide', additionalUnits <= 0);
            if (defaultEl) defaultEl.classList.toggle('hide', remainingCents <= 0);
            if (successEl) successEl.classList.toggle('hide', remainingCents > 0);
          }

          section.addEventListener('theme:variant:change', function (event) {
            var variant = event.detail && event.detail.variant;
            if (!variant) return;

            variantPriceCents = parseInt(variant.price, 10) || 0;
            note.setAttribute('data-variant-price', variantPriceCents);
            render();
          });

          document.addEventListener('theme:cart:change', function (event) {
            var cart = event.detail && event.detail.cart;
            if (!cart) return;

            cartTotalCents = parseInt(cart.total_price, 10) || 0;
            note.setAttribute('data-cart-total', cartTotalCents);
            render();
          });

          render();
        }

        document.querySelectorAll('[data-pdp-shipping-note]').forEach(initShippingNote);
      })();
    </script>
  {%- endif -%}
</div>
