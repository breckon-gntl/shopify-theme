<!-- /snippets/product-subscription.liquid -->
{%- comment -%}
  This block injects CRO visual styling for the Recharge subscription widget.
  Recharge's app embed provides all functional HTML/JS — we only add CSS here.
  Covers both the legacy class-based widget and the newer web component (::part).
{%- endcomment -%}

{%- if product.selling_plan_groups.size > 0 -%}

  <div class="product__block__subscription" style="--PB: {{ block.settings.padding_bottom }}px;" {{ block.shopify_attributes }}></div>

  <style>
    /* ── Recharge subscription widget — CRO card styles ── */

    /* CSS custom properties that Recharge reads (penetrate Shadow DOM) */
    :root {
      --rc-color-brand: #1b3731;
      --rc-color-brand-secondary: #1b3731;
      --rc-contrast-color: #fff6e4;
    }

    /* Widget container */
    .rc-container { margin-bottom: 0; }
    .rc-widget {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    /* === Card shell for each option === */
    .rc-option {
      border: 1.5px solid #dedad3 !important;
      border-radius: 8px !important;
      padding: 12px 14px !important;
      cursor: pointer;
      position: relative;
      transition: border-color 0.2s ease, background 0.2s ease;
      margin: 0 !important;
    }

    /* Active / selected card */
    .rc-option--active {
      border-color: #1b3731 !important;
      background: rgba(27, 55, 49, 0.04) !important;
    }

    /* "Best Value" badge — floats above the subscribe & save card */
    .rc-option__subsave {
      position: relative;
    }
    .rc-option__subsave::before {
      content: 'Best Value';
      position: absolute;
      top: -10px;
      left: 12px;
      background: #1b3731;
      color: #fff6e4;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.07em;
      padding: 2px 8px;
      border-radius: 20px;
      text-transform: uppercase;
      pointer-events: none;
    }

    /* Custom radio button */
    .rc-radio__input {
      -webkit-appearance: none;
      appearance: none;
      width: 17px !important;
      height: 17px !important;
      border: 1.5px solid #c8c4bc !important;
      border-radius: 50% !important;
      cursor: pointer;
      flex-shrink: 0;
      transition: all 0.15s ease;
      background: transparent;
    }
    .rc-option--active .rc-radio__input {
      border-color: #1b3731 !important;
      background: #1b3731 !important;
      box-shadow: inset 0 0 0 3px #fff6e4 !important;
    }

    /* Discount % pill */
    .rc-option__discount {
      background: rgba(27, 55, 49, 0.1) !important;
      color: #1b3731 !important;
      border-radius: 12px !important;
      padding: 2px 8px !important;
      font-size: 0.72rem !important;
      font-weight: 600 !important;
      border: none !important;
    }

    /* De-emphasize one-time */
    .rc-option__onetime {
      opacity: 0.72;
    }
    .rc-option__onetime.rc-option--active {
      opacity: 1;
    }

    /* Selling plan frequency — compact dropdown */
    .rc-selling-plans { margin-top: 8px; }
    .rc-selling-plans__dropdown {
      font-size: 0.82rem !important;
      border: 1px solid #dedad3 !important;
      border-radius: 6px !important;
      padding: 4px 8px !important;
      background: transparent;
    }

    /* === Newer Recharge web component ::part() selectors === */
    *::part(rc-content-wrap) {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    *::part(rc-purchase-option) {
      border: 1.5px solid #dedad3;
      border-radius: 8px;
      padding: 12px 14px;
      position: relative;
      transition: border-color 0.2s ease, background 0.2s ease;
    }
    *::part(rc-purchase-option__selected) {
      border-color: #1b3731;
      background: rgba(27, 55, 49, 0.04);
    }
    *::part(rc-purchase-option__badge) {
      background: rgba(27, 55, 49, 0.1);
      color: #1b3731;
      border-radius: 12px;
      padding: 2px 8px;
      font-weight: 600;
      font-size: 0.72rem;
      border: none;
    }
    *::part(rc-purchase-option__onetime) {
      opacity: 0.72;
    }
    *::part(rc-plans-button) {
      font-size: 0.78rem;
      border: 1px solid #c8c4bc;
      border-radius: 20px;
      padding: 3px 10px;
    }
  </style>

{%- endif -%}
