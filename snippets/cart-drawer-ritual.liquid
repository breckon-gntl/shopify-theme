<!-- /snippets/cart-drawer-ritual.liquid -->
{% comment %}
  Shows a cross-sell prompt in the cart drawer when only one ritual item
  (Skin Wash or Skin Emulsion) is present. Pre-renders both offer cards;
  JavaScript shows/hides the correct one based on live cart state.

  Uses plain <button type="button"> (no <form>) so the theme's own
  cart-form interceptor cannot double-handle the add-to-cart request.
{% endcomment %}

{%- assign p_wash = all_products['skin-wash'] -%}
{%- assign p_emulsion = all_products['skin-emulsion'] -%}

{%- if p_wash != blank and p_emulsion != blank -%}
  {%- assign wash_variant = p_wash.selected_or_first_available_variant -%}
  {%- assign emulsion_variant = p_emulsion.selected_or_first_available_variant -%}

  <div class="cart-ritual-xsell" data-cart-ritual-xsell style="display: none;">

    <p class="cart-ritual-xsell__heading">Complete your ritual</p>

    {%- comment %} Shown when only Skin Wash is in cart → suggest Skin Emulsion {%- endcomment -%}
    <div class="cart-ritual-xsell__offer" data-xsell-offer="skin-emulsion" style="display: none;">
      {%- if p_emulsion.featured_image -%}
        {%- assign emulsion_alt = p_emulsion.featured_image.alt | escape -%}
        <a href="{{ p_emulsion.url }}" class="cart-ritual-xsell__img-wrap" tabindex="-1" aria-hidden="true">
          {{ p_emulsion.featured_image | image_url: width: 160 | image_tag: loading: 'lazy', class: 'cart-ritual-xsell__img', alt: emulsion_alt }}
        </a>
      {%- endif -%}
      <div class="cart-ritual-xsell__info">
        <p class="cart-ritual-xsell__name">{{ p_emulsion.title }}</p>
        <p class="cart-ritual-xsell__price">{{ emulsion_variant.price | money }}</p>
        <button type="button"
          class="btn btn--primary cart-ritual-xsell__btn"
          data-xsell-add
          data-variant-id="{{ emulsion_variant.id }}">
          Add to Cart
        </button>
      </div>
    </div>

    {%- comment %} Shown when only Skin Emulsion is in cart → suggest Skin Wash {%- endcomment -%}
    <div class="cart-ritual-xsell__offer" data-xsell-offer="skin-wash" style="display: none;">
      {%- if p_wash.featured_image -%}
        {%- assign wash_alt = p_wash.featured_image.alt | escape -%}
        <a href="{{ p_wash.url }}" class="cart-ritual-xsell__img-wrap" tabindex="-1" aria-hidden="true">
          {{ p_wash.featured_image | image_url: width: 160 | image_tag: loading: 'lazy', class: 'cart-ritual-xsell__img', alt: wash_alt }}
        </a>
      {%- endif -%}
      <div class="cart-ritual-xsell__info">
        <p class="cart-ritual-xsell__name">{{ p_wash.title }}</p>
        <p class="cart-ritual-xsell__price">{{ wash_variant.price | money }}</p>
        <button type="button"
          class="btn btn--primary cart-ritual-xsell__btn"
          data-xsell-add
          data-variant-id="{{ wash_variant.id }}">
          Add to Cart
        </button>
      </div>
    </div>

  </div>

  <style>
    .cart-ritual-xsell {
      margin: 12px 16px;
      padding: 14px;
      background: #f5f2ee;
      border-radius: 8px;
    }
    .cart-ritual-xsell__heading {
      font-family: "PPEditorialNew", Georgia, serif;
      font-size: 0.95rem;
      color: #1b3731;
      margin: 0 0 10px;
    }
    .cart-ritual-xsell__offer {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .cart-ritual-xsell__img-wrap {
      flex: 0 0 auto;
      width: 64px;
      height: 64px;
      border-radius: 6px;
      overflow: hidden;
    }
    .cart-ritual-xsell__img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .cart-ritual-xsell__info {
      flex: 1;
      min-width: 0;
    }
    .cart-ritual-xsell__name {
      font-size: 0.82rem;
      font-weight: 600;
      margin: 0 0 2px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .cart-ritual-xsell__price {
      font-size: 0.8rem;
      opacity: 0.7;
      margin: 0 0 8px;
    }
    .cart-ritual-xsell__btn {
      width: 100%;
      padding: 8px 12px;
      font-size: 0.8rem;
    }
    .cart-ritual-xsell__btn.is-loading {
      opacity: 0.6;
      pointer-events: none;
    }
  </style>

  <script>
  (function () {
    function getCrossSellHandle(items) {
      var hasWash = false;
      var hasEmulsion = false;
      (items || []).forEach(function (item) {
        if (item.handle === 'skin-wash') hasWash = true;
        if (item.handle === 'skin-emulsion') hasEmulsion = true;
      });
      if (hasWash && !hasEmulsion) return 'skin-emulsion';
      if (hasEmulsion && !hasWash) return 'skin-wash';
      return null;
    }

    function updateXsell(cart) {
      var container = document.querySelector('[data-cart-ritual-xsell]');
      if (!container) return;
      var target = getCrossSellHandle(cart.items);
      container.querySelectorAll('[data-xsell-offer]').forEach(function (el) {
        el.style.display = 'none';
      });
      if (target) {
        var offer = container.querySelector('[data-xsell-offer="' + target + '"]');
        if (offer) {
          offer.style.display = '';
          container.style.display = '';
        }
      } else {
        container.style.display = 'none';
      }
    }

    // Re-render the cart drawer's line items and totals using the
    // Section Rendering API so the new item appears immediately.
    function refreshDrawerDOM() {
      var sectionEl = document.querySelector('[data-section-type="cart-drawer"]');
      var sectionId = sectionEl ? sectionEl.dataset.sectionId : null;
      if (!sectionId) return Promise.resolve();

      return fetch('/?sections=' + sectionId)
        .then(function (r) { return r.json(); })
        .then(function (data) {
          var html = data[sectionId];
          if (!html) return;
          var parser = new DOMParser();
          var doc = parser.parseFromString(html, 'text/html');

          // Swap line items
          var newItems = doc.querySelector('[data-line-items]');
          var curItems = document.querySelector('[data-line-items]');
          if (newItems && curItems) curItems.innerHTML = newItems.innerHTML;

          // Swap subtotal
          var newSub = doc.querySelector('[data-cart-subtotal]');
          var curSub = document.querySelector('[data-cart-subtotal]');
          if (newSub && curSub) curSub.innerHTML = newSub.innerHTML;

          // Swap checkout button total
          var newFinal = doc.querySelector('[data-cart-final]');
          var curFinal = document.querySelector('[data-cart-final]');
          if (newFinal && curFinal) curFinal.innerHTML = newFinal.innerHTML;
        });
    }

    function bindButtons() {
      document.querySelectorAll('[data-xsell-add]').forEach(function (btn) {
        if (btn.dataset.xsellBound) return;
        btn.dataset.xsellBound = '1';

        btn.addEventListener('click', function () {
          var variantId = btn.dataset.variantId;
          var originalText = btn.textContent.trim();
          btn.classList.add('is-loading');
          btn.textContent = 'Adding\u2026';

          fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: parseInt(variantId, 10), quantity: 1 })
          })
          .then(function (r) { return r.ok ? fetch('/cart.js') : Promise.reject(r); })
          .then(function (r) { return r.json(); })
          .then(function (cart) {
            // 1. Hide the cross-sell prompt
            updateXsell(cart);
            // 2. Update free-shipping bar and cart count badge
            document.dispatchEvent(new CustomEvent('theme:cart:change', { detail: { cart: cart } }));
            // 3. Re-render drawer line items in-place
            return refreshDrawerDOM();
          })
          .catch(function () {
            btn.classList.remove('is-loading');
            btn.textContent = originalText;
          });
        });
      });
    }

    // Initial state
    fetch('/cart.js')
      .then(function (r) { return r.json(); })
      .then(function (cart) {
        updateXsell(cart);
        bindButtons();
      });

    // Keep in sync with other cart changes
    document.addEventListener('theme:cart:change', function (e) {
      if (e.detail && e.detail.cart) {
        updateXsell(e.detail.cart);
        bindButtons();
      }
    });
  })();
  </script>

{%- endif -%}
