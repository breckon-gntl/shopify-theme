<!-- /snippets/pdp-trust-badges.liquid -->
{% comment %}
  Renders a horizontal row of trust badges below the ATC form.

  Label overrides (plain text, no HTML) can be passed via the render tag:
    badge_secure_text     {String}
    badge_guarantee_text  {String}
    badge_shipping_text   {String}
    guarantee_body        {String}

  Usage:
    {% render 'pdp-trust-badges' %}
{% endcomment %}

{%- assign _body  = guarantee_body | default: 'We stand behind our ritual with a no-questions-asked 30-day guarantee.' -%}
{%- assign _rating = product.metafields.reviews.rating.value.rating -%}

<div class="pdp-trust-badges">

  <div class="pdp-trust-badges__row">

    <div class="pdp-trust-badge">
      <span class="pdp-trust-badge__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6 6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.3.3 0 1 0 .2.3"/>
          <path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-4"/>
          <circle cx="20" cy="10" r="2"/>
        </svg>
      </span>
      <span class="pdp-trust-badge__label">Derm<br>tested</span>
    </div>

    <div class="pdp-trust-badge">
      <span class="pdp-trust-badge__icon">{%- render 'icon-setting', filename: 'icon-basket-return' -%}</span>
      <span class="pdp-trust-badge__label">
        {%- if badge_guarantee_text != blank -%}{{ badge_guarantee_text }}{%- else -%}30-day<br>money-back{%- endif -%}
      </span>
    </div>

    <div class="pdp-trust-badge">
      <span class="pdp-trust-badge__icon">{%- render 'icon-setting', filename: 'icon-truck' -%}</span>
      <span class="pdp-trust-badge__label">
        {%- if badge_shipping_text != blank -%}{{ badge_shipping_text }}{%- else -%}$5 flat-rate<br>shipping{%- endif -%}
      </span>
    </div>

    <div class="pdp-trust-badge">
      <span class="pdp-trust-badge__icon">{%- render 'icon-setting', filename: 'icon-star-rating' -%}</span>
      <a href="#" data-scroll-to-reviews class="pdp-trust-badge__label pdp-trust-badge__label--link">
        {%- if _rating != blank -%}
          {{- _rating | round: 1 -}}&thinsp;&#9733;<br>rating
        {%- else -%}
          4.9&thinsp;&#9733;<br>rating
        {%- endif -%}
      </a>
    </div>

  </div>

  <p class="pdp-trust-badges__guarantee">{{ _body }}</p>

</div>

<style>
  .pdp-trust-badges {
    margin-top: 16px;
  }
  .pdp-trust-badges__row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 0;
    padding: 14px 0;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  .pdp-trust-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    flex: 1 1 25%;
    min-width: 72px;
    text-align: center;
    padding: 0 8px;
  }
  .pdp-trust-badge + .pdp-trust-badge {
    border-left: 1px solid rgba(0, 0, 0, 0.08);
  }
  .pdp-trust-badge__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    color: #1b3731;
  }
  .pdp-trust-badge__icon svg {
    width: 22px;
    height: 22px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
  }
  .pdp-trust-badge__label {
    font-size: 0.68rem;
    line-height: 1.4;
    opacity: 0.7;
    color: inherit;
    text-decoration: none;
  }
  .pdp-trust-badge__label--link:hover {
    opacity: 1;
    text-decoration: underline;
  }
  .pdp-trust-badges__guarantee {
    font-size: 0.72rem;
    font-style: italic;
    opacity: 0.55;
    margin: 10px 0 0;
  }
  @media (max-width: 360px) {
    .pdp-trust-badges__row {
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .pdp-trust-badge {
      flex: 0 0 auto;
    }
  }
</style>

<script>
(function () {
  document.querySelectorAll('[data-scroll-to-reviews]').forEach(function (link) {
    link.addEventListener('click', function (e) {
      e.preventDefault();
      // All three product templates share this Klaviyo Reviews section ID
      var target = document.getElementById('shopify-section-1743609767405fe28f');
      // Fallback: find the full reviews list, not the inline average-rating widget
      if (!target) target = document.querySelector('[class*="kl_reviews__list"], [class*="kl_reviews__summary"]');
      if (!target) target = document.querySelector('[data-section-type="product-reviews"]');
      if (!target) return;
      // Offset for sticky header
      var header = document.querySelector('[data-header-sticky]');
      var offset = header ? header.offsetHeight : 0;
      var top = target.getBoundingClientRect().top + window.pageYOffset - offset - 16;
      window.scrollTo({ top: top, behavior: 'smooth' });
    });
  });
})();
</script>
